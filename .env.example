# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Africa's Talking SMS API Configuration for Bush SOS Emergency
AFRICAS_TALKING_API_KEY=YOUR_AFRICAS_TALKING_API_KEY
AFRICAS_TALKING_USERNAME=sandbox
AFRICAS_TALKING_TO=+254712345678
# MAPBOX_ACCESS_TOKEN: Required for Mapbox GL JS map tiles.
MAPBOX_ACCESS_TOKEN=pk.eyJ1IjoiZXhhbXBsZSIsImEiOiJjbHgxMjM0NTY3ODkwIn0.ABCDE12345
